#!/usr/bin/env python3
"""Scrape public Telegram channels and Nightwatch, write RSS feeds."""

import re
import sys
import html
import os
from urllib.request import urlopen, Request

CHANNELS = ["OSINTdefender"]
OUT_DIR = os.path.expanduser("~/.config/newsboat/tgrss")
UA = "Mozilla/5.0"


def strip_html(s):
    s = re.sub(r"<br\s*/?>", "\n", s)
    s = re.sub(r"<[^>]+>", "", s)
    return html.unescape(s).strip()


def fetch(url):
    req = Request(url, headers={"User-Agent": UA})
    with urlopen(req, timeout=15) as resp:
        return resp.read().decode("utf-8", errors="replace")


def esc(s):
    return s.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;").replace('"', "&quot;")


def write_rss(name, title, link, description, items, out_dir):
    os.makedirs(out_dir, exist_ok=True)
    path = os.path.join(out_dir, f"{name}.xml")

    rss = '<?xml version="1.0" encoding="utf-8"?>\n'
    rss += '<rss version="2.0">\n<channel>\n'
    rss += f"  <title>{esc(title)}</title>\n"
    rss += f"  <link>{esc(link)}</link>\n"
    rss += f"  <description>{esc(description)}</description>\n"

    for item in items:
        rss += "  <item>\n"
        rss += f"    <title>{esc(item['title'])}</title>\n"
        rss += f"    <link>{esc(item['link'])}</link>\n"
        rss += f"    <guid>{esc(item['link'])}</guid>\n"
        rss += f"    <pubDate>{esc(item['date'])}</pubDate>\n"
        rss += f"    <description>{esc(item['description'])}</description>\n"
        rss += "  </item>\n"

    rss += "</channel>\n</rss>\n"

    with open(path, "w") as f:
        f.write(rss)
    print(f"  {name}: {len(items)} items -> {path}")


# --- Telegram ---

def scrape_telegram(channel):
    page = fetch(f"https://t.me/s/{channel}")

    posts = re.findall(r'data-post="([^"]+)"', page)
    texts = re.findall(
        r'class="tgme_widget_message_text[^"]*"[^>]*>(.*?)</div>', page, re.DOTALL
    )
    dates = re.findall(
        r'class="tgme_widget_message_date"[^>]*>[^<]*<time[^>]*datetime="([^"]+)"',
        page, re.DOTALL,
    )

    items = []
    for i in range(min(len(posts), len(texts), len(dates))):
        post_id = posts[i].split("/")[-1]
        link = f"https://t.me/{channel}/{post_id}"
        body = texts[i]
        title = strip_html(body)[:120]
        if len(strip_html(body)) > 120:
            title += "..."
        items.append({"title": title, "link": link, "date": dates[i], "description": body})

    write_rss(channel, channel, f"https://t.me/s/{channel}", f"Telegram: {channel}", items, OUT_DIR)


# --- Nightwatch ---

def scrape_nightwatch():
    page = fetch("https://nightwatch.services/daily_reports")

    report_ids = re.findall(r'href="/daily_reports/(\d+)"', page)
    # Deduplicate, preserve order
    seen = set()
    unique_ids = []
    for rid in report_ids:
        if rid not in seen:
            seen.add(rid)
            unique_ids.append(rid)

    items = []
    for rid in unique_ids[:5]:
        try:
            rpage = fetch(f"https://nightwatch.services/daily_reports/{rid}")

            # Title from second h1 (the report headline)
            h1s = re.findall(r'<h1[^>]*>(.*?)</h1>', rpage, re.DOTALL)
            title = strip_html(h1s[1]) if len(h1s) > 1 else f"Daily Report #{rid}"

            # Date
            dates = re.findall(r'(\d{4}-\d{2}-\d{2})', rpage)
            date = dates[0] + "T00:00:00+00:00" if dates else ""

            # Content summary
            prose = re.search(
                r'class="prose prose-lg prose-invert max-w-none">(.*?)</div>\s*</div>',
                rpage, re.DOTALL,
            )
            desc = strip_html(prose.group(1))[:500] if prose else ""

            link = f"https://nightwatch.services/daily_reports/{rid}"
            items.append({"title": title, "link": link, "date": date, "description": desc})
        except Exception as e:
            print(f"  nightwatch #{rid}: error — {e}", file=sys.stderr)

    write_rss(
        "nightwatch", "Nightwatch", "https://nightwatch.services",
        "Military & Conflict Intelligence", items, OUT_DIR,
    )


def main():
    channels = CHANNELS
    if len(sys.argv) > 1:
        channels = sys.argv[1:]

    for ch in channels:
        try:
            scrape_telegram(ch)
        except Exception as e:
            print(f"  {ch}: error — {e}", file=sys.stderr)

    try:
        scrape_nightwatch()
    except Exception as e:
        print(f"  nightwatch: error — {e}", file=sys.stderr)


if __name__ == "__main__":
    main()
